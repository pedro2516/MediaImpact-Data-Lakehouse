    <worksheet name='Pergunta2'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#898989' fontname='Benton Sans Book' fontsize='12'>A Influência da Música na Rentabilidade</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Dados' name='federated.1y8yflb0yc2qkn1gngyfm02jt2ko' />
          </datasources>
          <datasource-dependencies datasource='federated.1y8yflb0yc2qkn1gngyfm02jt2ko'>
            <column caption='Filtro Música' datatype='boolean' name='[Calculation_1516024247452364838]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CONTAINS([prize_category], &quot;music&quot;)' />
            </column>
            <column caption='Tem Música (LOD)' datatype='integer' name='[Calculation_1516024247452540967]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [id_conteudo] : MAX(IF [Calculation_1516024247452364838] THEN 1 ELSE 0 END) }' />
            </column>
            <column caption='Categoria Final' datatype='string' name='[Calculation_1516024247452717096]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_1516024247452540967] = 1 THEN &quot;Com Música Original&quot; ELSE &quot;Sem Música Original&quot; END' />
            </column>
            <column caption='Audiovisual Profit' datatype='real' default-format='c#,##0,,M&quot; €&quot;;-#,##0,,M&quot; €&quot;' name='[audiovisual_profit]' role='measure' type='quantitative' />
            <column-instance column='[audiovisual_profit]' derivation='Avg' name='[avg:audiovisual_profit:qk]' pivot='key' type='quantitative' />
