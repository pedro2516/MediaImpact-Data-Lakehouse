    <worksheet name='Pergunta3'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#898989' fontname='Benton Sans Book' fontsize='12'>Relação entre Score do Público e Lucro Bruto</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Dados' name='federated.1y8yflb0yc2qkn1gngyfm02jt2ko' />
          </datasources>
          <datasource-dependencies datasource='federated.1y8yflb0yc2qkn1gngyfm02jt2ko'>
            <column caption='Rating Médio (Crítica + Público)' datatype='real' name='[Calculation_1516024247469211700]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([critic_score] + [public_score]) / 2' />
            </column>
            <column caption='Status Óscar' datatype='string' name='[Calculation_1516024247469289525]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IFNULL(&#13;&#10;    { FIXED [id_conteudo] : MAX(&#13;&#10;        IF CONTAINS(LOWER([cerimony]), &quot;academy&quot;) &#13;&#10;        THEN &quot;Nomeado Óscares&quot; &#13;&#10;        END&#13;&#10;    ) }, &#13;&#10;    &quot;Não Nomeado Óscares&quot;&#13;&#10;)' />
            </column>
            <column caption='Audiovisual Profit' datatype='real' default-format='c#,##0,,M&quot; €&quot;;-#,##0,,M&quot; €&quot;' name='[audiovisual_profit]' role='measure' type='quantitative' />
            <column caption='Cerimony' datatype='string' name='[cerimony]' role='dimension' type='nominal' />
            <column caption='Critic Score' datatype='integer' name='[critic_score]' role='measure' type='quantitative' />
            <column caption='Id Conteudo' datatype='integer' name='[id_conteudo]' role='dimension' type='ordinal' />
            <column-instance column='[Calculation_1516024247469211700]' derivation='None' name='[none:Calculation_1516024247469211700:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1516024247469289525]' derivation='None' name='[none:Calculation_1516024247469289525:nk]' pivot='key' type='nominal' />
            <column-instance column='[id_conteudo]' derivation='None' name='[none:id_conteudo:ok]' pivot='key' type='ordinal' />
            <column caption='Public Score' datatype='integer' name='[public_score]' role='measure' type='quantitative' />
            <column-instance column='[audiovisual_profit]' derivation='Sum' name='[sum:audiovisual_profit:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
