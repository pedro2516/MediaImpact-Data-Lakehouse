      <aliases enabled='yes' />
      <column caption='Faixa de Avaliação Público' datatype='string' name='[Calculation_1516024247275700233]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [public_score] &lt; 60 THEN &quot;Negativa&quot;&#13;&#10;ELSEIF [public_score] &lt;= 80 THEN &quot;Boa&quot;&#13;&#10;ELSE &quot;Excelente&quot;&#13;&#10;END' />
      </column>
      <column caption='Correlação Público vs Lucro' datatype='real' default-format='n#,##0.000;-#,##0.000' name='[Calculation_1516024247275790346]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CORR(FLOAT([public_score]), FLOAT([audiovisual_profit]))' />
      </column>
      <column caption='Filme com Música Nomeada' datatype='integer' name='[Calculation_1516024247282229262]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF CONTAINS(LOWER([prize_category]), &quot;music&quot;) THEN 1 ELSE 0 END' />
      </column>
      <column caption='Has Music Nom' datatype='integer' name='[Calculation_1516024247282286607]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [fk_content (fact_premios_cinem)] : &#13;&#10;  MAX(IF CONTAINS(LOWER([prize_category]), &quot;music&quot;) THEN 1 ELSE 0 END) &#13;&#10;}' />
      </column>
      <column caption='Diferença Percentual de Lucro' datatype='real' name='[Calculation_1516024247284207632]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(AVG(IF [Calculation_1516024247282286607] = 1 THEN [audiovisual_profit] END) / &#13;&#10;AVG(IF [Calculation_1516024247282286607] = 0 THEN [audiovisual_profit] END)) - 1' />
      </column>
      <column caption='Is Available' datatype='integer' name='[Calculation_1516024247284650001]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [plat_netflix] = 1 OR [plat_amazon] = 1 THEN 1 ELSE 0 END' />
      </column>
      <column caption='Lucro_Fixo_por_Filme' datatype='real' name='[Calculation_1516024247286034452]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [id_conteudo] : AVG([audiovisual_profit]) }' />
      </column>
      <column caption='Total_Premios' datatype='integer' name='[Calculation_1516024247287296025]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [id_conteudo] : SUM([n_wins]) }' />
      </column>
      <column caption='Taxa Netflix' datatype='real' name='[Calculation_1516024247307456539]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(FLOAT([plat_netflix]))' />
      </column>
      <column caption='Taxa Amazon' datatype='real' name='[Calculation_1516024247307517980]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(FLOAT([plat_amazon]))' />
      </column>
      <column caption='Taxa Vencedores' datatype='real' name='[Calculation_1516024247307620381]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF [n_wins] &gt; 0 THEN FLOAT([Calculation_1516024247284650001]) END)' />
      </column>
      <column caption='Taxa Nomeados' datatype='real' name='[Calculation_1516024247307710494]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF [n_wins] = 0 THEN FLOAT([Calculation_1516024247284650001]) END)' />
      </column>
      <column caption='IGD' datatype='real' default-format='p0%' name='[Calculation_1516024247307784223]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='( [Calculation_1516024247307456539] + [Calculation_1516024247307517980] + [Calculation_1516024247307620381] + [Calculation_1516024247307710494] ) / 4' />
      </column>
      <column caption='Cor IGD' datatype='string' name='[Calculation_1516024247308210208]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1516024247307784223] &gt;= 0.70 THEN &quot;Verde&quot;&#13;&#10;ELSEIF [Calculation_1516024247307784223] &gt;= 0.40 THEN &quot;Amarelo&quot;&#13;&#10;ELSE &quot;Vermelho&quot; END' />
      </column>
      <column caption='Média Disponibilidade Fixa' datatype='real' name='[Calculation_1516024247310209057]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [prize_category], [id_conteudo] : IF SUM([Calculation_1516024247284650001]) &gt; 0 THEN 1 ELSE 0 END }&#13;&#10;/&#13;&#10;{ FIXED [prize_category] : COUNTD([id_conteudo]) }' />
      </column>
      <column caption='Contar Dispononíveis' datatype='integer' name='[Calculation_1516024247314149410]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([id_conteudo])' />
      </column>
      <column caption='Investimento em Música Original' datatype='string' name='[Calculation_1516024247404593188]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [prize_category] = &quot;music (original score)&quot; &#13;&#10;OR [prize_category] = &quot;music (original song)&quot; &#13;&#10;OR [prize_category] = &quot;music (original song score or adaptation score)&quot; &#13;&#10;THEN &quot;Com Música Original&quot;&#13;&#10;ELSE &quot;Sem Música Original&quot;&#13;&#10;END' />
      </column>
      <column caption='Lucro Médio' datatype='real' datatype-customized='true' name='[Calculation_1516024247404736549]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='// Nome: Investimento em Música Original&#13;&#10;FLOAT(IF NOT ISNULL([prize_category]) AND (&#13;&#10;    [prize_category] = &quot;music (original score)&quot; OR &#13;&#10;    [prize_category] = &quot;music (original song)&quot; OR &#13;&#10;    [prize_category] = &quot;music (original song score or adaptation score)&quot;&#13;&#10;) THEN &quot;Com Música Original&quot;&#13;&#10;ELSE &quot;Sem Música Original&quot;&#13;&#10;END)' />
      </column>
      <column caption='Filtro Música' datatype='boolean' name='[Calculation_1516024247452364838]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CONTAINS([prize_category], &quot;music&quot;)' />
      </column>
      <column caption='Tem Música (LOD)' datatype='integer' name='[Calculation_1516024247452540967]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [id_conteudo] : MAX(IF [Calculation_1516024247452364838] THEN 1 ELSE 0 END) }' />
      </column>
      <column caption='Categoria Final' datatype='string' name='[Calculation_1516024247452717096]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1516024247452540967] = 1 THEN &quot;Com Música Original&quot; ELSE &quot;Sem Música Original&quot; END' />
      </column>
      <column caption='flag_musica' datatype='integer' name='[Calculation_1516024247456346153]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [id_conteudo] : MAX(IF CONTAINS(LOWER([prize_category]), &quot;music&quot;) THEN 1 ELSE 0 END) }' />
      </column>
      <column caption='flag_audio' datatype='integer' name='[Calculation_1516024247466033198]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [id_conteudo] : MAX(IF NOT ISNULL([id_audio_analysis]) THEN 1 ELSE 0 END) }' />
      </column>
      <column caption='n_premios' datatype='integer' name='[Calculation_1516024247466135599]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [id_conteudo] : COUNT([id_film_awards]) }' />
      </column>
      <column caption='lucro_por_filme' datatype='real' name='[Calculation_1516024247466217520]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [id_conteudo] : AVG([audiovisual_profit]) }' />
      </column>
      <column caption='Rating Médio (Crítica + Público)' datatype='real' name='[Calculation_1516024247469211700]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([critic_score] + [public_score]) / 2' />
      </column>
      <column caption='Status Óscar' datatype='string' name='[Calculation_1516024247469289525]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IFNULL(&#13;&#10;    { FIXED [id_conteudo] : MAX(&#13;&#10;        IF CONTAINS(LOWER([cerimony]), &quot;academy&quot;) &#13;&#10;        THEN &quot;Nomeado Óscares&quot; &#13;&#10;        END&#13;&#10;    ) }, &#13;&#10;    &quot;Não Nomeado Óscares&quot;&#13;&#10;)' />
      </column>
      <column caption='Correlação Qualidade/Lucro' datatype='real' name='[Calculation_1516024247469400118]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CORR([Calculation_1516024247469211700], [audiovisual_profit])' />
      </column>
      <column caption='Tipo de Exclusividade' datatype='string' name='[Calculation_1516024247482867767]' role='dimension' type='nominal'>
